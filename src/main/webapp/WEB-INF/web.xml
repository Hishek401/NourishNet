<?xml version="1.0" encoding="UTF-8"?>
<!--
    web.xml - Web Application Configuration File
    
    This file tells Tomcat how to run our web application.
    It's like a settings file for the entire project.
    
    Location: src/main/webapp/WEB-INF/web.xml
-->
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <!-- Display name shown in Tomcat Manager -->
    <display-name>NourishNet</display-name>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.ForgotPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <url-pattern>/forgot-password</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DonorDashboardServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.DonorDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DonorDashboardServlet</servlet-name>
        <url-pattern>/donor/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProfileServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.ProfileServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfileServlet</servlet-name>
        <url-pattern>/donor/profile</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SubmitDonationServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.SubmitDonationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmitDonationServlet</servlet-name>
        <url-pattern>/donor/donate</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DonorEditDonationServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.DonorEditDonationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DonorEditDonationServlet</servlet-name>
        <url-pattern>/donor/edit-donation</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ChangePasswordServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.ChangePasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ChangePasswordServlet</servlet-name>
        <url-pattern>/donor/change-password</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AboutServlet</servlet-name>
        <servlet-class>com.NourishNet.controller.AboutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AboutServlet</servlet-name>
        <url-pattern>/about</url-pattern>
    </servlet-mapping>

    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.NourishNet.filters.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 
        Welcome file: When someone visits http://localhost:8080/NourishNet/
        without specifying a page, redirect them to the login page.
    -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!--
        Session timeout: How long (in minutes) before an inactive user is logged out.
        30 minutes means if they do nothing for 30 min, they must login again.
    -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Custom error pages so users never see raw stack traces -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/pages/error/404.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/pages/error/500.jsp</location>
    </error-page>

</web-app>
